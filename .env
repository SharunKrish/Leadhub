# Django Security & Environment Configuration
# ---------------------------------------------
# Set to False in production
DEBUG=False

# A secure random key (override this in production!)
SECRET_KEY=django-insecure-0qf6#r*--zhi)7ykwe#1erb4mt96j$7x5u^=p*=f!!xe1__&th

# Comma-separated list of allowed hostnames/IPs
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
# ---------------------------------------------
# Optional: Set a database URL to use PostgreSQL/MySQL/etc. instead of SQLite
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
# DATABASE_URL=postgres://lead_user:secure_password@db:5432/lead_db
# DATABASE_SSL_REQUIRE=False

# CORS Configuration
# ---------------------------------------------
# Optional: Comma-separated list of allowed origins. Leave blank to allow all.
# CORS_ALLOWED_ORIGINS=https://example.com,https://dashboard.example.com

# Production Security Configurations
# ---------------------------------------------
# Redirect HTTP to HTTPS (set to True when behind load balancers terminating SSL)
# SECURE_SSL_REDIRECT=False
# Trust the X-Forwarded-Proto header from reverse proxies (default is True)
# SECURE_PROXY_SSL_HEADER=True

# Use secure cookies (defaults to True in production)
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HTTP Strict Transport Security (HSTS)
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Storage Directory for SQLite (used inside Docker to persist databases on volume mounts)
# SQLITE_DB_DIR=/app/db

# Logging
# ---------------------------------------------
# DJANGO_LOG_LEVEL=INFO
